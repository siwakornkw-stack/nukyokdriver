# Backend (vmbn-main) environment variables — set these in Vercel.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT secrets (generate NEW random strings; do not reuse the leaked ones)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_LIFETIME=15m
JWT_REFRESH_LIFETIME=7d

# Optional path prefix for all routes (leave empty unless you mount under /api)
API_URL=

# --- Redis ---
# Either a single URL (recommended on Vercel, e.g. Upstash):
REDIS_URL=
# ...or discrete values for a self-hosted Redis:
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Vercel Blob (file uploads) ---
# Auto-injected by Vercel when you create a Blob store; set locally for dev.
BLOB_READ_WRITE_TOKEN=
# Public base URL of the Blob store, NO trailing slash, e.g.
# https://xxxxxxxx.public.blob.vercel-storage.com
BLOB_PUBLIC_BASE_URL=

# Not needed on Vercel (serverless). Only used when running a local listener.
# PORT=8000
# NODE_ENV=production
