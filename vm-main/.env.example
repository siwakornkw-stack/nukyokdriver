# Frontend environment variables (set these in Vercel → Project → Settings → Environment Variables)

# Base URL of the backend API (vmbn-main), no trailing slash
NEXT_PUBLIC_URL_API=https://your-backend-domain.com

# Base URL where uploaded vehicle images are served from (usually same as the API host)
NEXT_PUBLIC_URL_IMAGE=https://your-backend-domain.com

# Hostname only (no protocol) for next/image remote images. Optional.
# Must match the host of NEXT_PUBLIC_URL_IMAGE if your images are served over https.
NEXT_PUBLIC_HOST_IMAGE=your-backend-domain.com
