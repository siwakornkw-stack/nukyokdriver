# Bot (vmbot-main) environment variables — set these in Vercel.

# PostgreSQL connection string (same database as the backend)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret that protects the /api/cron endpoint. Vercel Cron automatically sends
# `Authorization: Bearer <CRON_SECRET>`. Generate a random string.
CRON_SECRET=

# Local-only: node-cron schedule when running the bot as a long-lived process.
# On Vercel the schedule is set in vercel.json instead, so leave this empty.
# CRON_RUN=0 8 * * *
