generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AccidentVehicle {
  AccidentVehicleId String   @id @db.VarChar(36)
  Status            String   @db.VarChar(15)
  Date              DateTime
  Time              String
  Party             String
  LicensePlate      String
  DriverName        String
  Opponent          String
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  VehicleId         String   @db.VarChar(36)
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([AccidentVehicleId])
  @@index([VehicleId])
}

model Admin {
  AdminId            String               @id @db.VarChar(36)
  TenantId           String               @db.VarChar(36)
  ImageUrl           String?
  Username           String
  Password           String
  Email              String
  MobileNo           String               @db.VarChar(50)
  LineId             String?
  Status             String               @db.VarChar(15)
  LatestIpAddress    String               @db.VarChar(45)
  LatestLogin        DateTime?
  CreatedTime        DateTime             @default(now())
  UpdatedTime        DateTime             @default(now())
  DeletedTime        DateTime?
  DeletedByUsername  String?
  IsOnline           Boolean?
  LatestOnline       DateTime?
  PasswordHash       String
  Name               String?
  CreatedByUsername  String               @default("auto")
  Rank               String?              @db.VarChar(15)
  UpdatedByUsername  String?
  LineUserId         String?
  Tenant             Tenant               @relation(fields: [TenantId], references: [TenantId])
  RefreshTokensAdmin RefreshTokensAdmin[]

  @@index([AdminId])
  @@index([TenantId])
}

model AttachFileVehicle {
  AttachFileVehicleId String   @id @db.VarChar(36)
  FileName            String
  Description         String
  Url                 String
  CreatedAt           DateTime @default(now())
  UpdatedAt           DateTime @default(now())
  CreatedByUsername   String?
  UpdatedByUsername   String?
  VehicleId           String   @db.VarChar(36)
  Status              String   @db.VarChar(15)
  Vehicle             Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([AttachFileVehicleId])
  @@index([VehicleId])
}

model CarTires {
  CarTiresId        String   @id @db.VarChar(36)
  Status            String   @db.VarChar(15)
  ChangeDate        DateTime
  Position          String
  Brand             String
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  VehicleId         String   @db.VarChar(36)
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([CarTiresId])
  @@index([VehicleId])
}

model CompulsoryMotorInsuranceVehicle {
  CompulsoryMotorInsuranceVehicleId String   @id @db.VarChar(36)
  Status                            String   @db.VarChar(15)
  Year                              Int
  EndDate                           DateTime
  TotalPremium                      Decimal  @db.Decimal(10, 2)
  InsuranceCompany                  String
  BrokerName                        String
  VehicleId                         String   @db.VarChar(36)
  CreatedAt                         DateTime @default(now())
  CreatedByUsername                 String?
  UpdatedAt                         DateTime @default(now())
  UpdatedByUsername                 String?
  Vehicle                           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([CompulsoryMotorInsuranceVehicleId])
  @@index([VehicleId])
}

model Customer {
  CustomerId        String          @id @db.VarChar(36)
  TenantId          String          @db.VarChar(36)
  Username          String
  Password          String
  MobileNo          String          @db.VarChar(50)
  LineId            String?
  LatestIpAddress   String          @db.VarChar(45)
  LatestLogin       DateTime?
  Status            String          @db.VarChar(15)
  Role              String          @default("admin") @db.VarChar(20)
  CreatedTime       DateTime        @default(now())
  CreatedByUsername String          @default("auto")
  UpdatedTime       DateTime?
  UpdatedByUsername String?
  DeletedTime       DateTime?
  DeletedByUsername String?
  IsOnline          Boolean?
  LatestOnline      DateTime?
  Email             String?
  ImageUrl          String?
  PasswordHash      String
  Name              String?
  LineUserId        String?
  PinLine           String?         @db.VarChar(4)
  LinePinVerify     Boolean?
  Tenant            Tenant          @relation(fields: [TenantId], references: [TenantId])
  RefreshTokens     RefreshTokens[]

  @@index([CustomerId])
  @@index([TenantId])
}

model DomainName {
  DomainNameId String @id @db.VarChar(36)
  TenantId     String @db.VarChar(36)
  HostName     String
  Type         String @db.VarChar(15)
  Tenant       Tenant @relation(fields: [TenantId], references: [TenantId])

  @@index([HostName])
  @@index([TenantId])
}

model DrainTheOilVehicle {
  DrainTheOilVehicleId String   @id @db.VarChar(36)
  Status               String   @db.VarChar(15)
  Date                 DateTime
  TextAlert            String
  CreatedAt            DateTime @default(now())
  UpdatedAt            DateTime @default(now())
  CreatedByUsername    String?
  UpdatedByUsername    String?
  VehicleId            String   @db.VarChar(36)
  Vehicle              Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([DrainTheOilVehicleId])
  @@index([VehicleId])
}

model FuelType {
  FuelTypeId        String    @id @db.VarChar(36)
  Status            String    @db.VarChar(15)
  Name              String
  TenantId          String    @db.VarChar(36)
  CreatedAt         DateTime  @default(now())
  CreatedByUsername String?
  UpdatedAt         DateTime  @default(now())
  UpdatedByUsername String?
  Vehicle           Vehicle[]

  @@index([FuelTypeId])
  @@index([TenantId])
}

model GasolineCost {
  GasolineCostId    String   @id @db.VarChar(36)
  Status            String   @db.VarChar(15)
  Item              String
  Liters            Int
  Amount            Decimal  @db.Decimal(10, 2)
  OdometerStart     Int
  OdometerEnd       Int
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  VehicleId         String   @db.VarChar(36)
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([GasolineCostId])
  @@index([VehicleId])
}

model ImageVehicle {
  ImageVehicleId    String   @id @db.VarChar(36)
  Status            String   @db.VarChar(15)
  Url               String
  Title             String
  Description       String
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  VehicleId         String   @db.VarChar(36)
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([ImageVehicleId])
  @@index([VehicleId])
}

model InstallmentsVehicle {
  InstallmentsVehicleId String   @id @db.VarChar(36)
  Status                String   @db.VarChar(15)
  InstallmentNumber     Int
  DueDate               DateTime
  Amount                Decimal  @db.Decimal(10, 2)
  DatePay               DateTime?
  PaymentEvidence       String?
  CreatedAt             DateTime @default(now())
  UpdatedAt             DateTime @default(now())
  CreatedByUsername     String?
  UpdatedByUsername     String?
  VehicleId             String   @db.VarChar(36)
  Vehicle               Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([InstallmentsVehicleId])
  @@index([VehicleId])
}

model InsurancePolicyVehicle {
  InsurancePolicyVehicleId String   @id @db.VarChar(36)
  Status                   String   @db.VarChar(15)
  Year                     Int
  Type                     String
  InsuranceCompany         String
  BrokerName               String
  StartDate                DateTime
  EndDate                  DateTime
  TotalPremium             Decimal  @db.Decimal(10, 2)
  CreatedAt                DateTime @default(now())
  UpdatedAt                DateTime @default(now())
  CreatedByUsername        String?
  UpdatedByUsername        String?
  VehicleId                String   @db.VarChar(36)
  Vehicle                  Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([InsurancePolicyVehicleId])
  @@index([VehicleId])
}

model LineWebhook {
  LineWebhookId String   @id @db.VarChar(36)
  CreatedAt     DateTime @default(now())
  Body          String
  TenantId      String   @db.VarChar(36)

  @@index([LineWebhookId])
  @@index([TenantId])
}

model RefreshTokens {
  RefreshTokenId    String    @id @db.VarChar(36)
  HashedToken       String
  Revoked           Boolean   @default(false)
  CreatedTime       DateTime  @default(now())
  UpdatedTime       DateTime?
  CreatedByUsername String?
  UpdatedByUsername String?
  CustomerId        String    @db.VarChar(36)
  TenantId          String    @db.VarChar(36)
  Customer          Customer  @relation(fields: [CustomerId], references: [CustomerId], onDelete: Cascade)
  Tenant            Tenant    @relation(fields: [TenantId], references: [TenantId], onDelete: Cascade)

  @@index([CustomerId, TenantId])
  @@index([RefreshTokenId])
}

model RefreshTokensAdmin {
  RefreshTokenId    String    @id @db.VarChar(36)
  HashedToken       String
  Revoked           Boolean   @default(false)
  CreatedTime       DateTime  @default(now())
  UpdatedTime       DateTime?
  CreatedByUsername String?
  UpdatedByUsername String?
  AdminId           String    @db.VarChar(36)
  TenantId          String    @db.VarChar(36)
  Admin             Admin     @relation(fields: [AdminId], references: [AdminId], onDelete: Cascade)
  Tenant            Tenant    @relation(fields: [TenantId], references: [TenantId], onDelete: Cascade)

  @@index([AdminId, TenantId])
  @@index([RefreshTokenId])
}

model RepairVehicle {
  RepairVehicleId   String   @id @db.VarChar(36)
  Status            String   @db.VarChar(15)
  RepairDate        DateTime
  LicensePlate      String
  RepairShop        String
  ReceiveDate       DateTime
  InsurancePay      Decimal  @db.Decimal(10, 2)
  CompanyPay        Decimal  @db.Decimal(10, 2)
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  VehicleId         String   @db.VarChar(36)
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([RepairVehicleId])
  @@index([VehicleId])
}

model Setting {
  SettingConfigId String @id @db.VarChar(36)
  TenantId        String @db.VarChar(36)
  Key             String
  Value           String
  Category        String
  Tenant          Tenant @relation(fields: [TenantId], references: [TenantId])

  @@index([SettingConfigId])
  @@index([TenantId])
}

model Tax {
  TaxId             String   @id @db.VarChar(36)
  Year              Int
  EndDate           DateTime
  TotalPremium      Decimal  @db.Decimal(10, 2)
  InsuranceCompany  String
  BrokerName        String
  VehicleId         String   @db.VarChar(36)
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  Status            String   @db.VarChar(15)
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([TaxId])
  @@index([VehicleId])
}

model Tenant {
  TenantId               String               @id @db.VarChar(36)
  Name                   String
  Status                 String               @db.VarChar(15)
  Remark                 String?
  CreatedTime            DateTime             @default(now())
  UpdatedTime            DateTime             @default(now())
  SystemExpiredDate      DateTime
  LineChannelAccessToken String?
  LineImgUrl             String?
  Admin                  Admin[]
  Customer               Customer[]
  DomainName             DomainName[]
  RefreshTokens          RefreshTokens[]
  RefreshTokensAdmin     RefreshTokensAdmin[]
  Setting                Setting[]
  Vehicle                Vehicle[]

  @@index([TenantId])
}

model Vehicle {
  VehicleId                       String                            @id @db.VarChar(36)
  No                              Int                               @default(autoincrement())
  TenantId                        String                            @db.VarChar(36)
  LicensePlatePrefix              String
  LicensePlateSuffix              String
  LicensePlateProvince            String
  VehicleTypeId                   String?                           @db.VarChar(36)
  VehicleCharacteristic           String
  Model                           String
  Generation                      String
  Color                           String
  ChassisNumber                   String
  EngineNumber                    String
  EngineBrand                     String
  FuelTypeId                      String?                           @db.VarChar(36)
  TankSize                        Int
  FuelConsumption                 Int
  CylinderCount                   Int
  Cylinder                        Int
  VehicleSize                     String
  CargoSize                       String
  GasSerialNumber                 String
  VehicleWeight                   Int
  CargoWeight                     Int
  WheelCount                      Int
  SeatCount                       Int
  RegistrationDate                DateTime?
  StartDate                       DateTime?
  Age                             String
  Ownership                       String
  LineNotifyToken                 String?
  Note                            String?
  Img                             String?
  CreatedAt                       DateTime                          @default(now())
  UpdatedAt                       DateTime                          @default(now())
  VehicleBrandId                  String?                           @db.VarChar(36)
  VehicleDepartmentId             String?                           @db.VarChar(36)
  VehicleDriverId                 String?                           @db.VarChar(36)
  VehicleOwnerId                  String?                           @db.VarChar(36)
  VehicleStatusId                 String?                           @db.VarChar(36)
  CreatedByUsername               String?
  UpdatedByUsername               String?
  AccidentVehicle                 AccidentVehicle[]
  AttachFileVehicle               AttachFileVehicle[]
  CarTires                        CarTires[]
  CompulsoryMotorInsuranceVehicle CompulsoryMotorInsuranceVehicle[]
  DrainTheOilVehicle              DrainTheOilVehicle[]
  GasolineCost                    GasolineCost[]
  ImageVehicle                    ImageVehicle[]
  IncomeVehicle                   IncomeVehicle[]
  InstallmentsVehicle             InstallmentsVehicle[]
  InsurancePolicyVehicle          InsurancePolicyVehicle[]
  RepairVehicle                   RepairVehicle[]
  Tax                             Tax[]
  FuelType                        FuelType?                         @relation(fields: [FuelTypeId], references: [FuelTypeId])
  Tenant                          Tenant                            @relation(fields: [TenantId], references: [TenantId])
  VehicleBrand                    VehicleBrand?                     @relation(fields: [VehicleBrandId], references: [VehicleBrandId])
  VehicleDepartment               VehicleDepartment?                @relation(fields: [VehicleDepartmentId], references: [VehicleDepartmentId])
  VehicleDriver                   VehicleDriver?                    @relation(fields: [VehicleDriverId], references: [VehicleDriverId])
  VehicleOwner                    VehicleOwner?                     @relation(fields: [VehicleOwnerId], references: [VehicleOwnerId])
  VehicleStatus                   VehicleStatus?                    @relation(fields: [VehicleStatusId], references: [VehicleStatusId])
  VehicleType                     VehicleType?                      @relation(fields: [VehicleTypeId], references: [VehicleTypeId])

  @@index([TenantId])
  @@index([VehicleId])
}

model VehicleBrand {
  VehicleBrandId    String    @id @db.VarChar(36)
  Status            String    @db.VarChar(15)
  Name              String
  TenantId          String    @db.VarChar(36)
  CreatedAt         DateTime  @default(now())
  CreatedByUsername String?
  UpdatedAt         DateTime  @default(now())
  UpdatedByUsername String?
  Vehicle           Vehicle[]

  @@index([TenantId])
  @@index([VehicleBrandId])
}

model VehicleDepartment {
  VehicleDepartmentId String    @id @db.VarChar(36)
  Status              String    @db.VarChar(15)
  Name                String
  TenantId            String    @db.VarChar(36)
  CreatedAt           DateTime  @default(now())
  CreatedByUsername   String?
  UpdatedAt           DateTime  @default(now())
  UpdatedByUsername   String?
  Vehicle             Vehicle[]

  @@index([TenantId])
  @@index([VehicleDepartmentId])
}

model VehicleDriver {
  VehicleDriverId   String    @id @db.VarChar(36)
  Status            String    @db.VarChar(15)
  Name              String
  TenantId          String    @db.VarChar(36)
  CreatedAt         DateTime  @default(now())
  CreatedByUsername String?
  UpdatedAt         DateTime  @default(now())
  UpdatedByUsername String?
  Vehicle           Vehicle[]

  @@index([TenantId])
  @@index([VehicleDriverId])
}

model VehicleOwner {
  VehicleOwnerId    String    @id @db.VarChar(36)
  Status            String    @db.VarChar(15)
  Name              String
  TenantId          String    @db.VarChar(36)
  CreatedAt         DateTime  @default(now())
  CreatedByUsername String?
  UpdatedAt         DateTime  @default(now())
  UpdatedByUsername String?
  Vehicle           Vehicle[]

  @@index([TenantId])
  @@index([VehicleOwnerId])
}

model VehicleStatus {
  VehicleStatusId   String    @id @db.VarChar(36)
  Status            String    @db.VarChar(15)
  Name              String
  TenantId          String    @db.VarChar(36)
  CreatedAt         DateTime  @default(now())
  CreatedByUsername String?
  UpdatedAt         DateTime  @default(now())
  UpdatedByUsername String?
  Vehicle           Vehicle[]

  @@index([TenantId])
  @@index([VehicleStatusId])
}

model VehicleType {
  VehicleTypeId     String    @id @db.VarChar(36)
  Status            String    @db.VarChar(15)
  Name              String
  TenantId          String    @db.VarChar(36)
  CreatedAt         DateTime  @default(now())
  CreatedByUsername String?
  UpdatedAt         DateTime  @default(now())
  UpdatedByUsername String?
  Vehicle           Vehicle[]

  @@index([TenantId])
  @@index([VehicleTypeId])
}

model IncomeVehicle {
  IncomeVehicleId   String   @id @db.VarChar(36)
  Description       String
  Amount            Decimal  @db.Decimal(10, 2)
  Status            String   @db.VarChar(15)
  CreatedAt         DateTime @default(now())
  UpdatedAt         DateTime @default(now())
  CreatedByUsername String?
  UpdatedByUsername String?
  VehicleId         String   @db.VarChar(36)
  CustomerName      String?
  ReceiveDate       DateTime
  Vehicle           Vehicle  @relation(fields: [VehicleId], references: [VehicleId])

  @@index([IncomeVehicleId])
  @@index([VehicleId])
}
